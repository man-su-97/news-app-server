# Production — copy to `.env.prod` and fill in real secrets. NEVER commit `.env.prod`.
# The whole stack runs in Docker (see docker-compose.prod.yml), so services are
# reached by their compose service names (`db`, `redis`), not localhost.
#
# Run with:
#   docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build

# Postgres container credentials (used to initialise the db service).
POSTGRES_USER=news
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=news

# Must match the POSTGRES_* values above (host = compose service name `db`).
DATABASE_URL=postgresql+asyncpg://news:CHANGE_ME_STRONG_PASSWORD@db:5432/news
DEBUG=false

# --- AI layer ---
OPENAI_API_KEY=sk-REPLACE_ME
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
LLM_MODEL=gpt-4o-mini
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=5
# Hybrid retrieval (vector + full-text fused by Reciprocal Rank Fusion)
RETRIEVAL_CANDIDATE_N=50
RRF_K=60

# --- Token optimisation ---
LLM_MAX_TOKENS=512
RETRIEVAL_MIN_SCORE=0.2
MAX_CONTEXT_TOKENS=2000

# --- Rate limiting (host = compose service name `redis`) ---
REDIS_URL=redis://redis:6379/0
RATE_LIMIT_INDEX_PER_MIN=5
RATE_LIMIT_SEARCH_PER_MIN=60
RATE_LIMIT_ASK_PER_MIN=30
RATE_LIMIT_AGENT_PER_MIN=20

# --- Agent + safety ---
AGENT_MAX_ITERATIONS=6
SAFETY_ENABLED=true
