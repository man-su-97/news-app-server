# Local development — copy to `.env.local` and fill in secrets.
# App runs on the host (uvicorn --reload); Postgres + Redis run in Docker and are
# reached over localhost (see docker-compose.yml).

DATABASE_URL=postgresql+asyncpg://news:news@localhost:5432/news
DEBUG=true

# --- AI layer ---
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
LLM_MODEL=gpt-4o-mini
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=5
# Hybrid retrieval (vector + full-text fused by Reciprocal Rank Fusion)
RETRIEVAL_CANDIDATE_N=50
RRF_K=60

# --- Token optimisation ---
LLM_MAX_TOKENS=512
RETRIEVAL_MIN_SCORE=0.2
MAX_CONTEXT_TOKENS=2000

# --- Rate limiting ---
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_INDEX_PER_MIN=5
RATE_LIMIT_SEARCH_PER_MIN=30
RATE_LIMIT_ASK_PER_MIN=20
RATE_LIMIT_AGENT_PER_MIN=15

# --- Agent + safety ---
AGENT_MAX_ITERATIONS=6
SAFETY_ENABLED=true
